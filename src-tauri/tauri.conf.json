{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "structura",
  "version": "0.1.0",
  "identifier": "dev.sajidmehmoodtariq.structura",
  "build": {
    "frontendDist": "../structura/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix structura",
    "beforeBuildCommand": "npm run build --prefix structura"
  },
  "app": {
    "windows": [
      {
        "title": "Structura",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
